# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Persistence files with secrets — never commit
.ai-config.json
.capital-credentials.json
.system-settings.json
.users.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Mission Control runtime logs
lib/data/mission-control-event-log.json

# Autonomous Trading Evolution runtime memory
lib/data/autonomous-trading-evolution-memory.json
